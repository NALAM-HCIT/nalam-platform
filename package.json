{
  "name": "nalam-app",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:hospital": "sh -c 'cp .env.$HOSPITAL .env && eas build --platform $PLATFORM --profile ${HOSPITAL:-production}'",
    "build:arunpriya:android": "HOSPITAL=arunpriya PLATFORM=android npm run build:hospital",
    "build:arunpriya:ios": "HOSPITAL=arunpriya PLATFORM=ios npm run build:hospital"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.0.0",
    "@react-navigation/drawer": "^7.0.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "@supabase/supabase-js": "^2.99.3",
    "@tanstack/react-query": "^5.0.0",
    "axios": "^1.7.0",
    "base64-arraybuffer": "^1.0.2",
    "buffer": "^6.0.3",
    "expo": "~55.0.0",
    "expo-blur": "~55.0.10",
    "expo-build-properties": "~55.0.10",
    "expo-camera": "~55.0.10",
    "expo-file-system": "~55.0.11",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "~55.0.9",
    "expo-linking": "~55.0.8",
    "expo-local-authentication": "~55.0.9",
    "expo-modules-core": "^55.0.17",
    "expo-notifications": "~55.0.14",
    "expo-router": "~55.0.7",
    "expo-secure-store": "~55.0.9",
    "expo-sharing": "~55.0.14",
    "expo-splash-screen": "~55.0.12",
    "expo-status-bar": "~55.0.4",
    "lucide-react-native": "~0.577.0",
    "nativewind": "^4.0.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-agora": "^4.6.2",
    "react-native-css-interop": "~0.2.0",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-razorpay": "^2.3.1",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-worklets": "0.7.2",
    "zustand": "^5.0.0"
